# Android upload-keystore credentials.
#
# 1. Generate a keystore (keep the .jks OUTSIDE the repo):
#      keytool -genkey -v -keystore ~/keys/notes-app-upload.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias upload
# 2. Copy this file to `key.properties` (same folder) and fill in the values.
# 3. `key.properties` and keystore files are git-ignored — never commit them.
#    Losing this keystore means you can no longer update the app on Google Play.

storePassword=your-store-password
keyPassword=your-key-password
keyAlias=upload
storeFile=/absolute/path/to/notes-app-upload.jks
